<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GlassToKey.Linux.Gui.MainWindow"
        Width="1320"
        Height="980"
        MinWidth="1180"
        MinHeight="860"
        Title="GlassToKey Linux Control">
  <Grid RowDefinitions="Auto,*">
    <Border Background="#23303A" Padding="24,18">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="GlassToKey Linux"
                     FontSize="28"
                     FontWeight="Bold"
                     Foreground="#F7F2EA" />
          <TextBlock Text="Device binding and config for the tray-owned Linux runtime"
                     FontSize="14"
                     Foreground="#D9C7B5" />
        </StackPanel>
        <Border Background="#E07845"
                CornerRadius="12"
                Padding="14,8"
                VerticalAlignment="Center">
          <TextBlock x:Name="PhaseBadgeText"
                     Text="Phase 4 / 6"
                     FontWeight="SemiBold"
                     Foreground="#FFF7F0" />
        </Border>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1"
                  Margin="24"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="18">
        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Trackpads" />
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
              <StackPanel Spacing="8">
                <TextBlock Text="Left trackpad" />
                <ComboBox x:Name="LeftDeviceCombo" MinWidth="320" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="8">
                <TextBlock Text="Right trackpad" />
                <ComboBox x:Name="RightDeviceCombo" MinWidth="320" />
              </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
              <Button x:Name="RefreshDevicesButton" Classes="action" Content="Refresh Devices" />
              <Button x:Name="SwapSidesButton" Content="Swap Sides" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Settings" />

            <TextBlock Text="Layout preset" />
            <ComboBox x:Name="LayoutPresetCombo" MinWidth="240" />

            <TextBlock Text="Keymap path" Margin="0,8,0,0" />
            <TextBox x:Name="KeymapPathBox" Watermark="Use bundled Linux default when empty" />
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button x:Name="BrowseKeymapButton" Content="Browse Keymap" />
              <Button x:Name="ClearKeymapButton" Content="Use Bundled Default" />
            </StackPanel>
            <TextBlock x:Name="KeymapStatusText"
                       TextWrapping="Wrap"
                       Foreground="#5A4032" />

            <TextBlock x:Name="SettingsPathText"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Foreground="#5A4032" />

            <TextBlock x:Name="RuntimeSummaryText"
                       TextWrapping="Wrap"
                       Foreground="#23303A" />
            <TextBlock x:Name="RuntimeBindingsText"
                       TextWrapping="Wrap"
                       Foreground="#5A4032" />

            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
              <Button x:Name="SaveSettingsButton" Classes="action" Content="Save Settings" />
              <Button x:Name="InitializeDefaultsButton" Content="Init Defaults" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Live Input Preview" />
            <TextBlock Text="Reads evdev directly so you can inspect contact motion against the active loaded keymap while the tray-owned runtime stays off the GUI hotpath."
                       TextWrapping="Wrap"
                       Foreground="#5A4032" />

            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button x:Name="StartPreviewButton" Classes="action" Content="Start Preview" />
              <Button x:Name="StopPreviewButton" Content="Stop Preview" />
            </StackPanel>

            <TextBlock x:Name="PreviewSummaryText"
                       TextWrapping="Wrap"
                       Foreground="#23303A" />

            <Grid ColumnDefinitions="*,*">
              <Border Background="#FFF3E6" BorderBrush="#D9C7B5" BorderThickness="1" CornerRadius="12" Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="Left Trackpad"
                             FontWeight="SemiBold"
                             Foreground="#5A4032" />
                  <Canvas x:Name="LeftPreviewCanvas"
                          Width="520"
                          Height="312"
                          Background="#FFF9F1" />
                  <TextBlock x:Name="LeftPreviewText"
                             TextWrapping="Wrap"
                             Foreground="#5A4032" />
                </StackPanel>
              </Border>

              <Border Grid.Column="1" Margin="12,0,0,0" Background="#FFF3E6" BorderBrush="#D9C7B5" BorderThickness="1" CornerRadius="12" Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="Right Trackpad"
                             FontWeight="SemiBold"
                             Foreground="#5A4032" />
                  <Canvas x:Name="RightPreviewCanvas"
                          Width="520"
                          Height="312"
                          Background="#FFF9F1" />
                  <TextBlock x:Name="RightPreviewText"
                             TextWrapping="Wrap"
                             Foreground="#5A4032" />
                </StackPanel>
              </Border>
            </Grid>

            <Border Background="#0C0F12"
                    BorderBrush="#2B2F33"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12,10"
                    Margin="0,8,0,0">
              <StackPanel Spacing="6">
                <TextBlock Text="Typing Test"
                           Foreground="#8B949E"
                           FontSize="12" />
                <TextBox x:Name="TypingTestBox"
                         Height="54"
                         AcceptsReturn="True"
                         TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Status" />
            <TextBlock x:Name="StatusText"
                       TextWrapping="Wrap"
                       Foreground="#23303A" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
